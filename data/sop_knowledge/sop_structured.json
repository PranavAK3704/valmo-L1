      "not paid",
      "payment short",
      "count mismatch consumables",
      "billing cycle"
    ],
    "required_inputs": [
      "hub_id",
      "order_id",
      "billing_cycle"
    ],
    "validation_rules": [
      {
        "field": "hub_id",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain"
      },
      {
        "field": "order_id",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain"
      }
    ],
    "data_sources": {
      "metabase_queries": [
        "captain_payout_query"
      ],
      "filter_by": [
        "hub_id"
      ],
      "columns_to_check": [
        "rvp_consumable_amount",
        "rvp_consumable_packet_count",
        "rvp_consumable_rate"
      ],
      "validation_formula": "rate × count = amount"
    },
    "note": "High fraud risk on this queue — validate ordered vs. claimed packets before processing. Payment processed 2 weeks after order cycle. Manual entries (Scenario 3) follow same payment cycle as Scenario 2.",
    "scenarios": [
      {
        "scenario_id": "CON_PAY_1",
        "label": "Payment received for fewer consumables than ordered (X of Y, X<Y)",
        "conditions": [
          "rvp_consumable_packet_count < captain_claimed_count"
        ],
        "action": "escalate",
        "steps": [
          "Enter hub_id into captain_payout_query",
          "Check rvp_consumable_amount, rvp_consumable_packet_count, rvp_consumable_rate",
          "Validate: rate × count = amount",
          "If count_in_query < captain_stated_count → escalate to L3 (Cost-Ops)"
        ],
        "escalation": {
          "level": "L3",
          "team": "cost_ops",
          "reason": "Count mismatch in consumable payment — post-validation escalation"
        },
        "response_to_captain": "We have verified your payment data. The count discrepancy has been escalated to our Cost-Ops team for resolution."
      },
      {
        "scenario_id": "CON_PAY_1b",
        "label": "Payment received for fewer consumables — count MATCHES query",
        "conditions": [
          "rvp_consumable_packet_count == captain_claimed_count"
        ],
        "action": "respond",
        "response_to_captain": "We have verified your consumable payment. The count in our records matches your stated count. Payment details shared.",
        "template": "con_pay_count_match_template"
      },
      {
        "scenario_id": "CON_PAY_2",
        "label": "No payment received for any consumables ordered (full non-payment)",
        "conditions": [
          "rvp_consumable_packet_count == 0 OR rvp_consumable_packet_count == null"
        ],
        "action": "respond",
        "steps": [
          "Enter hub_id into captain_payout_query",
          "Check payment cycles mentioned by partner",
          "If count ~0 for mentioned cycles: classify as arrear",
          "Payment processing happens 2 weeks after the cycle order was made",
          "Reply with arrear template"
        ],
        "response_to_captain": "Your consumable payment appears to be pending as an arrear. Payments are processed 2 weeks after the order cycle. Please allow the cycle to complete.",
        "template": "con_pay_arrear_template"
      },
      {
        "scenario_id": "CON_PAY_3",
        "label": "Manual entries post scan failure — payment not processed",
        "conditions": [
          "captain_issue == manual_entries_after_scan_failure"
        ],
        "note": "No method to verify manual entries independently. Payment follows Scenario 2 (CON_PAY_2) cycle — processed in the cycle following the order cycle.",
        "action": "respond",
        "response_to_captain": "For orders with scan failures requiring manual entry, payment is processed in the cycle following your order cycle (per April timeline). Please allow the cycle to complete.",
        "template": "con_pay_manual_entry_template"
      }
    ]
  },
