[
  {
    "problem_theme": "hardstop_loss",
    "type": "hardstop_loss",
    "queue": "W- LD",
    "tat_hours": 72,
    "intent": "captain_contests_hardstop_loss_marking",
    "trigger_keywords": [
      "hardstop",
      "loss marked",
      "wrong loss",
      "reversal",
      "5 days",
      "not connected"
    ],
    "required_inputs": [
      "awb_numbers"
    ],
    "validation_rules": [
      {
        "field": "awb_numbers",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain",
        "template": "missing_awb_template"
      }
    ],
    "preprocessing": {
      "note": "If scan shows node with naming PCXX = Packaging Center, AWB is consolidated into a parent. Do NOT process child AWB — find parent AWB via Single AWB Tracking query and process that instead.",
      "parent_awb_lookup": "single_awb_tracking_query",
      "bag_id_to_awb": "If ticket has Bag IDs (format: UN followed by digits, e.g. UN117197848) but no AWB numbers — enter the Bag ID in the Valmo 2k24 lost Metabase query to extract the individual AWB numbers. Do NOT ask captain for AWBs if Bag IDs are present."
    },
    "data_sources": {
      "metabase_queries": [
        "loss_attribution_check",
        "lm_fe_loss_marked",
        "seller_dependency_attempts"
      ],
      "log10": "single_awb_scan_history"
    },
    "hardstop_rule": {
      "forward_shipment_max_days": 7,
      "reverse_shipment_max_days": 5,
      "description": "Any shipment arriving at hub must be connected forward within 5 days (reverse) or 7 days (forward). Breach = loss stands."
    },
    "scenarios": [
      {
        "scenario_id": "HS_1_1",
        "label": "Scans valid + Hardstop SOP followed → reversal",
        "conditions": [
          "log10_scans == valid_connection",
          "hardstop_sop_followed == true"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "Valid scans + SOP followed → eligible for reversal"
        },
        "response_to_captain": "Loss marked against your shipments will be reversed.",
        "template": "hardstop_reversal_template"
      },
      {
        "scenario_id": "HS_1_2",
        "label": "Scans valid + Hardstop SOP NOT followed → no reversal",
        "conditions": [
          "log10_scans == valid_connection",
          "hardstop_sop_followed == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "response_to_captain": "Reversal not applicable — Hardstop SOP was not followed.",
        "template": "hardstop_sop_breach_template"
      },
      {
        "scenario_id": "HS_2",
        "label": "Scans invalid (wrong destination connection) → no reversal",
        "conditions": [
          "log10_scans == wrong_destination_connection"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "response_to_captain": "Reversal not applicable — wrong connection destination detected in scans.",
        "template": "hardstop_wrong_connection_template"
      },
      {
        "scenario_id": "HS_3",
        "label": "Customer Rejection → no forward connection in RTO timeline → no reversal",
        "conditions": [
          "captain_reason == customer_rejection",
          "log10_scans.forward_connection_within_rto_timeline == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "response_to_captain": "Reversal not applicable — no forward connection within RTO timeline.",
        "template": "hardstop_reversal_na_template"
      },
      {
        "scenario_id": "HS_4",
        "label": "Customer Unreachable → shipment not delivered within 7 days → no reversal",
        "conditions": [
          "captain_reason == customer_unreachable",
          "log10_scans.delivered_within_7_days == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "response_to_captain": "Reversal not applicable — shipment not delivered within 7 days.",
        "template": "hardstop_reversal_na_template"
      },
      {
        "scenario_id": "HS_5",
        "label": "Customer denies OTP → <3 attempts or not delivered in 7 days → no reversal",
        "conditions": [
          "captain_reason == customer_denies_otp",
          "log10_scans.delivery_attempts_within_7_days < 3",
          "log10_scans.delivered_within_7_days == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "response_to_captain": "Reversal not applicable — fewer than 3 delivery attempts within 7 days.",
        "template": "hardstop_reversal_na_template"
      },
      {
        "scenario_id": "HS_6",
        "label": "Customer wants shipment post 7 days → <3 attempts or not delivered → no reversal",
        "conditions": [
          "captain_reason == customer_wants_post_7_days",
          "log10_scans.delivery_attempts_within_7_days < 3",
          "log10_scans.delivered_within_7_days == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "additional_instruction": "Inform captain that customer should cancel and reorder.",
        "response_to_captain": "Loss not applicable for reversal. Delivery must be attempted 3 times per SOP. Please advise customer to cancel and reorder.",
        "template": "hardstop_reversal_na_template"
      },
      {
        "scenario_id": "HS_7",
        "label": "Shipment delivered but couldn't be marked → direct to tech team",
        "conditions": [
          "captain_reason == delivered_but_could_not_mark"
        ],
        "action": "respond",
        "decision": "direct_to_tech",
        "response_to_captain": "Please raise this issue directly with the tech team along with relevant proof of delivery.",
        "template": "hardstop_tech_team_template"
      },
      {
        "scenario_id": "HS_8_1",
        "label": "Not inscanned to hub + FE amount RECOVERED → reversal",
        "conditions": [
          "captain_reason == shipment_not_inscanned_to_hub",
          "metabase.lm_fe_loss_marked.amount_recovered_from_fe == true"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "Amount recovered from FE → eligible for reversal"
        },
        "response_to_captain": "Loss marked against your shipments will be reversed.",
        "template": "hardstop_reversal_template"
      },
      {
        "scenario_id": "HS_8_2",
        "label": "Not inscanned to hub + FE amount NOT recovered + Consignment_Lost status → reversal",
        "conditions": [
          "captain_reason == shipment_not_inscanned_to_hub",
          "metabase.lm_fe_loss_marked.amount_recovered_from_fe == false",
          "log10_scans.last_status == Consignment_Lost"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "Amount not recovered + Consignment_Lost confirmed → eligible for reversal"
        },
        "response_to_captain": "Loss marked against your shipments will be reversed.",
        "template": "hardstop_reversal_template"
      },
      {
        "scenario_id": "HS_9_1",
        "label": "Awaited instruction (seller dependency) + SOP BREACHED → no reversal",
        "conditions": [
          "captain_reason == awaited_instruction_seller_dependency",
          "metabase.seller_dependency_attempts.sop_followed == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "response_to_captain": "No reversal — Seller Dependency SOP was not followed.",
        "template": "hardstop_sop_breach_template"
      },
      {
        "scenario_id": "HS_9_2",
        "label": "Awaited instruction (seller dependency) + SOP FOLLOWED → reversal",
        "conditions": [
          "captain_reason == awaited_instruction_seller_dependency",
          "metabase.seller_dependency_attempts.sop_followed == true"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "Seller Dependency SOP followed → eligible for reversal"
        },
        "response_to_captain": "Loss marked against your shipments will be reversed.",
        "template": "hardstop_reversal_template"
      },
      {
        "scenario_id": "HS_10",
        "label": "Wrong shipment/bag received (misrouted, deadline missed) → no reversal",
        "conditions": [
          "captain_reason == wrong_shipment_or_bag_received",
          "log10_scans.misroute_within_2_days == false"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "note": "For bags: use Bag ID tracking query. If unavailable, enter all AWBs in bag individually.",
        "response_to_captain": "No reversal applicable — shipments not routed to correct hub within 2-day misroute deadline.",
        "template": "hardstop_reversal_na_template"
      },
      {
        "scenario_id": "HS_11_1",
        "label": "Correctly misrouted (MISROUTE scan within 2 days) → reversal",
        "conditions": [
          "captain_reason == misrouted_shipment",
          "log10_scans.misroute_scan_within_2_days == true"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "MISROUTE scan within 2-day window — valid misroute → eligible for reversal"
        },
        "response_to_captain": "Loss will be reversed — misroute was detected within the valid window."
      },
      {
        "scenario_id": "HS_11_2",
        "label": "Incorrectly misrouted (back-and-forth beyond limit) → no reversal",
        "conditions": [
          "captain_reason == misrouted_shipment",
          "log10_scans.back_and_forth_misroute_count > 2"
        ],
        "action": "respond",
        "decision": "close_no_reversal",
        "note": "Shipments bouncing between 2 hubs — maximum 2 misroutes allowed. Loss attributed to original hub.",
        "response_to_captain": "No reversal applicable — shipments exceeded maximum misroute allowance.",
        "template": "hardstop_reversal_na_template"
      },
      {
        "scenario_id": "HS_WAIVER",
        "label": "Hardstop Loss Waiver — captain meets all waiver eligibility conditions",
        "conditions": [
          "captain_tenure_days < 60",
          "prior_hardstop_reversals == 0",
          "invoice_cycles_generated >= 1",
          "current_hardstop_pendency == 0"
        ],
        "note": "ALL four conditions must be met simultaneously. If any fails, waiver not applicable — treat as standard hardstop scenario.",
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "Captain meets all waiver eligibility — tenure <60 days, no prior reversals, invoice generated, zero current pendency"
        },
        "response_to_captain": "Your case meets the eligibility criteria for a hardstop waiver. We are escalating this for review."
      }
    ]
  },
  {
    "problem_theme": "shortage_loss",
    "type": "shortage_loss",
    "queue": "shipment_shortage",
    "queue_aliases": [
      "W- LD",
      "losses & debits"
    ],
    "tat_hours": 72,
    "intent": "captain_contests_shortage_loss_attribution",
    "trigger_keywords": [
      "shortage",
      "short",
      "missing shipment",
      "bag shortage",
      "evidence",
      "CCTV"
    ],
    "required_inputs": [
      "awb_numbers"
    ],
    "validation_rules": [
      {
        "field": "awb_numbers",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain",
        "template": "missing_awb_template"
      }
    ],
    "data_sources": {
      "metabase_queries": [
        "loss_attribution_check",
        "shortage_data_query"
      ],
      "log10": "single_awb_scan_history"
    },
    "derived_conditions": {
      "mails_sent_to_both_partners": "shortage_data_query.marked_location_mail_status == sent AND shortage_data_query.assigned_location_mail_status == sent",
      "ticket_within_24hrs": "ticket_created_time - vehicle_arrival_timestamp <= 24h",
      "marked_location_sla_breached": "shortage_data_query.marked_location_ticket_status == SLA_BREACHED",
      "assigned_location_sla_breached": "shortage_data_query.assigned_location_ticket_status == SLA_BREACHED"
    },
    "scenarios": [
      {
        "scenario_id": "SL_1",
        "label": "Evidence/reply mails not sent to one or all partners → re-queue mails",
        "conditions": [
          "mails_sent_to_both_partners == false"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L3",
          "system": "kapture",
          "type": "direct",
          "reason": "Mails not triggered to all required partners — L3 to re-queue"
        },
        "response_to_captain": "We have identified that evidence emails were not sent to all required partners. Re-escalating to ensure correct communication."
      },
      {
        "scenario_id": "SL_2",
        "label": "Captain unable to mark shortage → check SOP compliance",
        "conditions": [
          "captain_issue == unable_to_mark_shortage"
        ],
        "decision_tree": [
          {
            "if": "ticket_within_24hrs == true AND shortage_data_query.status == CLOSED",
            "then": "mark_as_tech_issue",
            "action": "respond",
            "template": "tech_issue_template"
          },
          {
            "if": "ticket_within_24hrs == false",
            "then": "sop_breach_reject",
            "action": "respond",
            "template": "shortage_sop_breach_template"
          }
        ]
      },
      {
        "scenario_id": "SL_3",
        "label": "One partner shared evidence, other has not → loss attributed to non-compliant partner",
        "conditions": [
          "marked_location_sla_breached == true OR assigned_location_sla_breached == true"
        ],
        "action": "respond",
        "decision": "attribute_loss_to_non_compliant_partner",
        "note": "SLA_BREACHED status = partner did not share evidence in time. CLOSED ≠ SLA_BREACHED — do not confuse.",
        "response_to_captain": "Loss has been attributed to the partner that did not share evidence within the required timeframe per shortage SOP."
      },
      {
        "scenario_id": "SL_4",
        "label": "Both partners shared evidence but loss marked on one → escalate for evidence validation",
        "conditions": [
          "marked_location_sla_breached == false",
          "assigned_location_sla_breached == false",
          "captain_contesting_attribution == true"
        ],
        "action": "escalate",
        "escalation": {
          "level": "L2",
          "reason": "Both partners submitted evidence — requires trained team to validate and determine correct attribution"
        },
        "response_to_captain": "Both partners have submitted evidence. Escalating to the evidence validation team for review."
      },
      {
        "scenario_id": "SL_5",
        "label": "Captain claims wrong email ID was shared",
        "conditions": [
          "captain_issue == wrong_email_id_shared"
        ],
        "action": "respond",
        "decision": "inform_should_have_raised_earlier",
        "response_to_captain": "You should have intimated this previously. Following the required process.",
        "template": "shortage_wrong_email_template"
      }
    ],
    "preprocessing": {
      "bag_id_to_awb": "If ticket has Bag IDs (format: UN + digits) but no AWB numbers — use the Valmo 2k24 lost Metabase query with the Bag ID to get individual AWBs. Do NOT use needs_info to ask for AWBs when Bag IDs are present."
    }
  },
  {
    "problem_theme": "consumables_order",
    "type": "consumables",
    "queue": "C_V",
    "tat_hours": 24,
    "intent": "captain_query_about_consumables_order",
    "trigger_keywords": [
      "consumables",
      "flyer",
      "polybag",
      "docket",
      "order",
      "packaging material",
      "RVP"
    ],
    "required_inputs": [
      "order_id",
      "hub_id"
    ],
    "validation_rules": [
      {
        "field": "order_id",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain",
        "template": "missing_order_hub_id_template"
      },
      {
        "field": "hub_id",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain",
        "template": "missing_order_hub_id_template"
      }
    ],
    "data_sources": {
      "sheets": [
        "rvp_consumables_partner_details"
      ],
      "columns_to_check": [
        "supplier_code",
        "dispatch_date",
        "delivery_date",
        "order_status",
        "docket_no",
        "courier_name",
        "order_details",
        "qty"
      ]
    },
    "scenarios": [
      {
        "scenario_id": "CON_1",
        "label": "Captain wants to know how to place an order",
        "conditions": [
          "captain_issue == how_to_place_order"
        ],
        "action": "respond",
        "response_to_captain": "Guide captain on how to place consumables order.",
        "template": "consumables_order_process_template"
      },
      {
        "scenario_id": "CON_2",
        "label": "Captain unable to order — not whitelisted",
        "conditions": [
          "captain_issue == not_whitelisted"
        ],
        "required_inputs_for_scenario": [
          "hub_id",
          "order_id"
        ],
        "action": "respond",
        "steps": [
          "Verify all required details present in ticket",
          "If missing: request using template",
          "If present: upload details to whitelisting sheet",
          "Reply to captain confirming completion"
        ],
        "template": "consumables_whitelisting_complete_template"
      },
      {
        "scenario_id": "CON_3",
        "label": "Captain wants to track order / hasn't received on time",
        "conditions": [
          "captain_issue == track_order OR captain_issue == order_delayed"
        ],
        "action": "respond",
        "decision_tree": [
          {
            "if": "rvp_sheet.order_status == Delivered",
            "then": "loop_in_supplier_via_email",
            "note": "Email linked to supplier_code in supplier sheet"
          },
          {
            "if": "rvp_sheet.order_status == Dispatched",
            "then": "provide_tracking_info",
            "steps": [
              "Go to courier named in courier_name column",
              "Enter docket_no as tracking ID",
              "Reply to captain with tracking status and instructions to self-track"
            ],
            "template": "consumables_track_order_template"
          }
        ]
      },
      {
        "scenario_id": "CON_4",
        "label": "Captain received fewer consumables than ordered",
        "conditions": [
          "captain_issue == received_less_than_ordered"
        ],
        "action": "respond",
        "decision_tree": [
          {
            "if": "quantity_matches == true AND rvp_sheet.order_status == Delivered",
            "then": "loop_in_supplier",
            "template": "consumables_shortage_delivered_template"
          },
          {
            "if": "quantity_matches == true AND rvp_sheet.order_status == Dispatched",
            "then": "reply_dispatched",
            "template": "consumables_shortage_dispatched_template"
          },
          {
            "if": "quantity_matches == false",
            "then": "loop_in_supplier_immediately"
          }
        ]
      }
    ]
  },
  {
    "problem_theme": "consumables_quality",
    "type": "consumables",
    "queue": "C_V",
    "tat_hours": 24,
    "intent": "captain_reports_consumables_quality_issue",
    "trigger_keywords": [
      "damaged",
      "broken",
      "defective",
      "QC",
      "quality",
      "secondary QC"
    ],
    "required_inputs": [
      "order_id",
      "hub_id",
      "proof_of_damage"
    ],
    "validation_rules": [
      {
        "field": "required_info_present",
        "condition": "all_fields_valid",
        "action_if_failed": "request_input_from_captain",
        "template": "consumables_missing_info_template"
      }
    ],
    "data_sources": {
      "sheets": [
        "rvp_consumables_partner_details"
      ],
      "supplier_email_lookup": "supplier_code_to_email_map"
    },
    "scenarios": [
      {
        "scenario_id": "CON_QC_1",
        "label": "Damaged consumables received",
        "conditions": [
          "captain_issue == damaged_consumables_received"
        ],
        "action": "respond",
        "steps": [
          "Validate required info is present and valid",
          "If not: request using template",
          "Loop in supplier via email linked to supplier_code",
          "Reply to captain acknowledging and confirming supplier looped in"
        ],
        "template": "consumables_damaged_template"
      },
      {
        "scenario_id": "CON_QC_2",
        "label": "Secondary QC failure",
        "conditions": [
          "captain_issue == secondary_qc_failure"
        ],
        "action": "respond",
        "steps": [
          "Validate required info is present and valid",
          "If not: request using template",
          "Follow QC failure resolution process"
        ],
        "template": "consumables_qc_failure_template"
      }
    ]
  },
  {
    "problem_theme": "payment_not_received",
    "type": "payments",
    "queue": "M_V",
    "tat_hours": 12,
    "intent": "captain_has_not_received_payment",
    "trigger_keywords": [
      "payment",
      "not received",
      "invoice",
      "payout",
      "pendency"
    ],
    "required_inputs": [
      "payment_cycle",
      "enbolt_id",
      "invoice_number"
    ],
    "validation_rules": [
      {
        "field": "payment_cycle",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain"
      },
      {
        "field": "enbolt_id",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain"
      }
    ],
    "data_sources": {
      "metabase_queries": [
        "captain_payment_status_and_amount"
      ],
      "filter_by": [
        "hub_code",
        "invoice_number",
        "enbolt_id"
      ],
      "key_column": "Remarks"
    },
    "scenarios": [
      {
        "scenario_id": "PAY_1",
        "label": "Payment processed — based on Remarks column status",
        "conditions": [
          "metabase.captain_payment.remarks != null"
        ],
        "action": "respond",
        "decision_tree": [
          {
            "if": "remarks == Payment_processed",
            "then": "respond",
            "template": "payment_processed_template"
          },
          {
            "if": "remarks == Pending_E_Sign",
            "then": "respond",
            "template": "pending_esign_template"
          },
          {
            "if": "remarks == Hold_Negative",
            "then": "respond",
            "template": "hold_negative_template"
          },
          {
            "if": "remarks == GST_Defaulter_Hold",
            "then": "respond",
            "template": "gst_defaulter_template"
          },
          {
            "if": "remarks == Risk_COD_pendency",
            "then": "respond",
            "template": "risk_cod_pendency_template"
          },
          {
            "if": "remarks == Risk_COD_Shipment_pendency",
            "then": "respond",
            "template": "risk_cod_shipment_template"
          },
          {
            "if": "remarks == Risk_Open_losses",
            "then": "respond",
            "template": "risk_open_losses_template"
          },
          {
            "if": "remarks == Risk_COD_Shipment_Open_losses",
            "then": "respond",
            "template": "risk_combined_template"
          },
          {
            "if": "remarks == Grocery_Defaulter",
            "then": "respond",
            "template": "grocery_defaulter_template"
          },
          {
            "if": "remarks == GST_above_20L",
            "then": "respond",
            "template": "gst_above_20l_template"
          },
          {
            "if": "remarks == DC_under_FnF",
            "then": "respond",
            "template": "dc_fnf_template"
          },
          {
            "if": "remarks == Payout_Hold_by_ops",
            "then": "respond",
            "template": "hold_by_ops_template"
          },
          {
            "if": "remarks == Payment_Failed",
            "then": "respond",
            "template": "payment_failed_template"
          }
        ]
      }
    ]
  },
  {
    "problem_theme": "full_and_final_settlement",
    "type": "payments",
    "queue": "M_V",
    "tat_hours": null,
    "intent": "captain_requests_fnf_settlement",
    "trigger_keywords": [
      "FnF",
      "full and final",
      "settlement",
      "final settlement",
      "SD refund"
    ],
    "required_inputs": [
      "hub_code",
      "enbolt_id"
    ],
    "validation_rules": [
      {
        "field": "hub_code",
        "condition": "not_empty",
        "action_if_failed": "request_input_from_captain"
      }
    ],
    "data_sources": {
